# ==========================================
# Simul-Interpreter 配置文件模板
# 请复制此文件为 .env 并填入真实信息
# ==========================================

# [必填] OpenAI API Key
# 获取地址: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# [可选] 模型配置
# 聊天/翻译模型 (推荐: gpt-4o, gpt-4o-mini, gpt-5.1)
OPENAI_CHAT_MODEL=gpt-4o-mini

# TTS 语音模型 (推荐: tts-1, tts-1-hd, gpt-4o-mini-tts)
OPENAI_TTS_MODEL=tts-1

# TTS 发音人 (alloy, echo, fable, onyx, nova, shimmer)
TTS_VOICE=alloy

# [可选] Whisper 模型配置
# 可选: tiny, base, small, medium, large-v3
# 显存小选 small, 追求精度选 large-v3
WHISPER_MODEL=small

# [可选] 音频参数 (一般无需修改)
AUDIO_RATE=16000
AUDIO_CHUNK=1024
SLICE_DURATION=0.7
